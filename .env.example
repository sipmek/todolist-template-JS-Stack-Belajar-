# ========================================
# TODO LIST APPLICATION - ENVIRONMENT SETUP
# ========================================
# CATATAN: Copy file ini menjadi .env dan isi dengan nilai yang sesuai
# DO NOT COMMIT .env ke repository (sudah di .gitignore)
# COMMIT hanya .env.example supaya tahu env apa saja yang diperlukan

# ========================================
# SERVER CONFIGURATION
# ========================================
# Port yang digunakan server backend (default: 5000)
PORT=5000

# Environment mode (development, production, staging)
NODE_ENV=development

# ========================================
# JWT CONFIGURATION
# ========================================
# JWT Secret Key untuk sign/verify token
# HARUS diganti dengan string random yang KUAT (minimal 32 karakter)
# Generate: openssl rand -base64 32
# ⚠️ JANGAN PERNAH gunakan value default di production!
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production_12345

# ========================================
# DATABASE CONFIGURATION (MySQL)
# ========================================
# Connection string ke database (format MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="mysql://root:@localhost:3306/todolist_db"

# User yang punya akses ke database
DATABASE_USER=root

# Password database user (kosong jika tidak ada password - XAMPP default)
DATABASE_PASSWORD=

# Nama database yang digunakan
DATABASE_NAME=todolist_db

# Host/IP address MySQL server
DATABASE_HOST=localhost

# Port MySQL server (default: 3306)
DATABASE_PORT=3306

# ========================================
# OPSIONAL - UNTUK PRODUCTION NANTI
# ========================================
# Email untuk error notifications
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# Frontend URL (untuk CORS di production)
# FRONTEND_URL=http://localhost:5173

# Sentry untuk error tracking
# SENTRY_DSN=https://your-sentry-key
